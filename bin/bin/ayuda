#!/usr/bin/env python3

from rich.console import Console
from rich.markdown import Markdown


def muestra():
    """Muestra el archivo README.md"""
    with open("/home/felipe/.dotfiles/README.md", "r") as f:
        data = f.read()
        console = Console()
        md = Markdown(data)
        console.print(md)


if __name__ == "__main__":
    muestra()
