#!/usr/bin/env python3
import os
import sys
from datetime import date, timedelta

now = date.today()


def gastos(numero_meses=6):
    meses = now - timedelta(days=30 * numero_meses)
    comando = f"hledger is -M -2 -S -b {meses}"
    os.system(comando)


def diario(numero_dias=6):
    dias = now - timedelta(days=numero_dias)
    comando = f"hledger is -D -2 -S -b {dias}"
    print(comando)
    os.system(comando)


def anual(numero_anios=8):
    anios = now - timedelta(days=365 * numero_anios)
    comando = f"hledger is -Y -2 -S -b {anios}"
    os.system(comando)


def balance():
    comando = "hledger balancesheet"
    os.system(comando)


def semanal(numero_semanas=5):
    semanas = now - timedelta(days=7 * numero_semanas)
    comando = f"hledger is -W -2 -S -b {semanas}"
    os.system(comando)


def mensual(numero_meses=5):
    meses = now - timedelta(days=30 * numero_meses)
    comando = f"hledger is -M -2 -S -b {meses}"
    os.system(comando)


if __name__ == "__main__":
    if len(sys.argv) > 1:
        param = sys.argv[1].lower()

        if param == "gastos":
            gastos()
        elif param == "diario":
            diario()
        elif param == "anual":
            anual()
        elif param == "balance":
            balance()
        elif param == "semanal":
            semanal()
        elif param == "mensual":
            mensual()
    else:
        print("Falta un parámetro")
